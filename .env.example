# Canonical URL for OG tags, sitemap, and SITE_CONFIG.url (include https, no trailing slash).
# On Vercel you can omit this — VERCEL_URL is used automatically. Set when you use a custom domain:
# NEXT_PUBLIC_SITE_URL=https://newperspectivesupportservices.com

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Who receives contact form leads (comma-separated). Optional — defaults to Dan + realnickpatrick@gmail.com
RESEND_TO_EMAIL=Dan@newperspectivesupportservices.com,realnickpatrick@gmail.com

# Sender — MUST be quoted if it contains spaces or angle brackets (Resend-verified domain).
# Use an address on your verified domain, e.g. contact@ or hello@
RESEND_FROM_EMAIL="New Perspective Website <contact@newperspectivesupportservices.com>"

# Legacy aliases (still supported if you already set these in Vercel):
# CONTACT_TO_EMAIL=same as RESEND_TO_EMAIL
# CONTACT_FROM_EMAIL=same as RESEND_FROM_EMAIL
