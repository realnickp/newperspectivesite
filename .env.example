# Canonical URL for OG tags, sitemap, and SITE_CONFIG.url (include https, no trailing slash).
# On Vercel you can omit this — VERCEL_URL is used automatically. Set when you use a custom domain:
# NEXT_PUBLIC_SITE_URL=https://newperspectivesupportservices.com

# Get an API key at https://resend.com — free tier is enough to start.
RESEND_API_KEY=re_xxxxxxxx

# Comma-separated list of inboxes that receive contact form leads.
# If omitted, defaults to Dan@newperspectivesupportservices.com and realnickpatrick@gmail.com
CONTACT_TO_EMAIL=Dan@newperspectivesupportservices.com,realnickpatrick@gmail.com

# Sender (must use an address on a domain verified in Resend)
CONTACT_FROM_EMAIL=New Perspective Website <contact@newperspectivesupportservices.com>
