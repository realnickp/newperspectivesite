# Get an API key at https://resend.com — free tier is enough to start.
RESEND_API_KEY=re_xxxxxxxx

# Where form submissions are delivered (defaults to SITE_CONFIG.email if omitted)
CONTACT_TO_EMAIL=Dan@newperspectivesupportservices.com

# Sender shown in the inbox. After you verify your domain in Resend, use e.g.
#   New Perspective Website <contact@newperspectivesupportservices.com>
# For quick testing only, Resend allows:
#   New Perspective Website <onboarding@resend.dev>
# (with onboarding@resend.dev, Resend may only deliver to addresses allowed on your account)
CONTACT_FROM_EMAIL=New Perspective Website <onboarding@resend.dev>
